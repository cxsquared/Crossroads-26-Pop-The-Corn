[sub_resource type="GDScript" id="GDScript_ygvoh"]
script/source = "extends Label


# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	_on_level_score_updated(0)


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(_delta: float) -> void:
	pass


func _on_level_score_updated(new_score: int) -> void:
	text = \"You still need %d popcorns popped\" % max(0, Global.current_run.get_current_wave_target() - new_score)
"

